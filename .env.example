# Crown E-Auction Platform - Environment Variables Template
# Copy this file to .env.local for local development
# Never commit real credentials - use this template as reference

# ============================================
# Supabase Configuration
# ============================================

# Supabase Project URL
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (public, safe for frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase Service Role Key (SECRET - for backend/scripts only)
# NEVER expose this in frontend code!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Legacy alias for service role key (some scripts may use this)
SUPABASE_ADMIN_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ============================================
# Database Direct Connection (for migrations)
# ============================================

# PostgreSQL connection string
# Get from: Supabase Dashboard > Database > Connection String > Connection Pooling
PG_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ============================================
# Google Cloud (for Cloud Tasks)
# ============================================

# Usually not needed - automatically loaded via gcloud CLI
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================
# OpenRouter API (for GPT/AI features)
# ============================================

# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key

# ============================================
# Intercom (for support chat)
# ============================================

# Get from: Intercom Settings > Installation > Web
# IMPORTANT: Use NUXT_PUBLIC_ prefix for variables accessible in browser
NUXT_PUBLIC_INTERCOM_APP_ID=your-app-id
INTERCOM_ACCESS_TOKEN=your-access-token
INTERCOM_SECRET_KEY=********************

# Enable/disable Intercom widget
# Disabled locally by default - enabled on DEV/PROD via Vercel env vars
ENABLE_INTERCOM=false

# ============================================
# Sentry (error tracking)
# ============================================

# Get from: Sentry Settings > Projects > Your Project > Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Auth token for releases (optional)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# Application Configuration
# ============================================

# Node environment
NODE_ENV=development

# Application URL (used for absolute URLs, emails, etc.)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Instructions
# ============================================

# 1. Copy this file:
#    cp .env.example .env.local

# 2. Fill in the values from Supabase Dashboard and other services

# 3. For production scripts, download from Vercel:
#    vercel env pull .env.production --environment=production

# 4. Never commit .env.local or .env.production to Git!

# 5. Run scripts with environment flags:
#    node scripts/run.js <script-name> --local
#    node scripts/run.js <script-name> --production
