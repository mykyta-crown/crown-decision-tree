{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "test-engine": "node scripts/engineCall.js",
    "migrate": "npx supabase db push --db-url \"$PG_URL\"",
    "build": "nuxt build",
    "build:skip-migrate": "nuxt build",
    "build:local": "NITRO_PRESET=node-server nuxt build",
    "preview:local": "NITRO_PRESET=node-server nuxt preview",
    "engine": "node crown/scripts/engineCall.js",
    "dev": "nuxt dev --no-fork",
    "dev:fresh": "pkill -f 'nuxt dev' 2>/dev/null; sleep 1; nuxt dev --no-fork",
    "deploy": "git push origin main && git push playground main",
    "dev:ngrok": "nuxt dev & sleep 3 && ngrok http 3000",
    "test_jap_plan": "node scripts/api_testing/v1/japanese/engineCallJapanese.js",
    "test_jap_bider": "node scripts/api_testing/v1/japanese/emulateBids.js",
    "test_jap_round": "node scripts/api_testing/v1/japanese/emulateRoundHandler.js",
    "test_dutch_ender": "node scripts/api_testing/dutchPrebidEnder.js",
    "test_task_enqueue": "node scripts/api_testing/tasksEnqueuing.js",
    "test_auction_update_prebids": "node scripts/api_testing/dutchAuctionUpdatePreBids.js",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "script": "node scripts/run.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:changed": "eslint $(git diff --name-only --diff-filter=ACM main...HEAD | grep -E '\\.(js|ts|vue)$' | xargs) || true",
    "lint:changed:fix": "eslint --fix $(git diff --name-only --diff-filter=ACM main...HEAD | grep -E '\\.(js|ts|vue)$' | xargs) || true",
    "format": "prettier \"**/*.{js,ts,vue,md,json,css,scss}\" --write",
    "format:check": "prettier \"**/*.{js,ts,vue,md,json,css,scss}\" --check",
    "format:changed": "prettier --write $(git diff --name-only --diff-filter=ACM main...HEAD | grep -E '\\.(js|ts|vue|md|json|css|scss)$' | xargs) || true",
    "prepare": "husky || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@date-io/dayjs": "^3.0.0",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/tasks": "4.0.1",
    "@intercom/messenger-js-sdk": "^0.0.17",
    "@mdi/font": "^7.4.47",
    "@nuxtjs/supabase": "^2.0.1",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^8.45.1",
    "@sparticuz/chromium": "^141.0.0",
    "@supabase/supabase-js": "^2.57.2",
    "@types/pg": "^8.11.10",
    "@vercel/analytics": "^1.3.1",
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/components": "^11.1.0",
    "@vueuse/core": "^11.1.0",
    "@vueuse/sound": "^2.0.1",
    "chart.js": "^4.4.4",
    "chartjs-adapter-dayjs-4": "^1.0.4",
    "d3": "^7.9.0",
    "dayjs": "^1.11.13",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "logrocket": "^9.0.0",
    "mammoth": "^1.11.0",
    "marked": "^15.0.7",
    "pg": "^8.13.3",
    "pinia": "^3.0.4",
    "puppeteer-core": "^24.28.0",
    "unpdf": "^1.4.0",
    "vue": "^3.5.6",
    "vue-chartjs": "^5.3.1",
    "vue-router": "^4.4.5",
    "vue3-carousel": "^0.3.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nuxt/content": "^2.13.4",
    "@nuxt/eslint": "^1.11.0",
    "@nuxt/scripts": "^0.9.2",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@stylistic/eslint-plugin-js": "^1.6.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nuxt": "3.15.4",
    "prettier": "^3.7.4",
    "puppeteer": "^24.29.1",
    "sass": "^1.78.0",
    "sass-loader": "^16.0.1",
    "supabase": "^2.65.7",
    "vitest": "^4.0.18",
    "vuetify": "3.7.8",
    "vuetify-nuxt-module": "^0.18.3"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write"
    ],
    "*.{md,json,css,scss}": [
      "prettier --write"
    ]
  }
}
